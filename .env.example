# Add these in Vercel → Project Settings → Environment Variables.
# Never commit real secret values.

# Server-side only: keep private.
GEMINI_API_KEY=replace_with_your_private_gemini_key
GEMINI_MODEL=gemini-3.5-flash

# Browser configuration: safe to expose only when Row Level Security is enabled.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace_with_your_supabase_publishable_key
